VERSION 0.8

image:
    # Use Debian variant — PHP packages need apt-get
    ARG SCRIPTS_VERSION=main-debian
    FROM earthly/lunar-scripts:$SCRIPTS_VERSION

    RUN apt-get update -qq && \
        apt-get install -y --no-install-recommends php-cli php-json php-xml && \
        rm -rf /var/lib/apt/lists/*

    # Install Composer
    RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer

    # Verify installations
    RUN php --version && composer --version

    ARG VERSION=main
    SAVE IMAGE --push earthly/lunar-lib:php-$VERSION
