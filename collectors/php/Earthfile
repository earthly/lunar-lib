VERSION 0.8

image:
    FROM --pass-args ../../+base-image

    # Install PHP CLI
    RUN apk add --no-cache php83 php83-json php83-phar php83-mbstring php83-openssl php83-curl php83-tokenizer php83-xml php83-xmlwriter && \
        ln -sf /usr/bin/php83 /usr/bin/php

    # Install Composer
    RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer

    # Verify installations
    RUN php -v && composer --version

    ARG VERSION=main
    SAVE IMAGE --push earthly/lunar-lib:php-$VERSION
