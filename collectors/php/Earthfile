VERSION 0.8

image:
    FROM --pass-args ../../+base-image

    # Install PHP CLI and Composer
    RUN apt-get update && \
        apt-get install -y --no-install-recommends php-cli php-json php-xml && \
        rm -rf /var/lib/apt/lists/*

    # Install Composer
    RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer

    # Verify installations
    RUN php --version && composer --version

    ARG VERSION=main
    SAVE IMAGE --push earthly/lunar-lib:php-$VERSION
