VERSION 0.8

image:
    FROM --pass-args ../../+base-image

    # OpenJDK + sbt — sbt is in Alpine community since 3.18.
    # Mill is fetched as a static native runner (no JDK download).
    RUN apk add --no-cache openjdk17-jre bash curl ca-certificates sbt

    # Mill bootstrap script (resolves a versioned launcher on first run).
    RUN curl -fsSL https://raw.githubusercontent.com/lefou/millw/main/millw -o /usr/local/bin/mill && \
        chmod +x /usr/local/bin/mill

    RUN sbt --version || true
    RUN mill --version || true

    ARG VERSION=main
    SAVE IMAGE --push earthly/lunar-lib:scala-$VERSION
