{
  "annotation_match": {
    "_comment": "Standard case: Backstage Component with the github.com/project-slug annotation matching $LUNAR_COMPONENT_ID via prefix",
    "_component_id": "github.com/acme/payment-api",
    "catalog": {
      "native": {
        "backstage": {
          "valid": true,
          "apiVersion": "backstage.io/v1alpha1",
          "kind": "Component",
          "metadata": {
            "name": "payment-api",
            "namespace": "default",
            "annotations": {
              "github.com/project-slug": "acme/payment-api"
            },
            "tags": ["payments", "tier1"]
          },
          "spec": {
            "type": "service",
            "lifecycle": "production",
            "owner": "group:default/team-payments",
            "domain": "platform.payments"
          }
        }
      }
    }
  },
