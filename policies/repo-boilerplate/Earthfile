VERSION 0.8

# Unit tests for the CODEOWNERS repo-boilerplate policies. Wired into the root
# +test target. (No image: target — repo-boilerplate policies run on the shared
# base image.)
test:
    FROM python:3.12-alpine
    WORKDIR /workspace
    COPY requirements.txt .
    RUN pip install --no-cache-dir -r requirements.txt
    COPY *.py .
    RUN python -m unittest test_codeowners_policies -v
