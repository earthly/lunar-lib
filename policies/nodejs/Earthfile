VERSION 0.8

# Unit tests for the Node.js policy checks. Wired into the root +test target.
# (No image: target — the nodejs policy runs on the shared base image.)
test:
    FROM python:3.12-alpine
    WORKDIR /workspace
    COPY requirements.txt .
    RUN pip install --no-cache-dir -r requirements.txt
    COPY --dir checks .
    COPY --dir test .
    RUN python test/test_project_gating.py
